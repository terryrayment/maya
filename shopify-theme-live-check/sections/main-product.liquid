{% liquid
  assign details = product.metafields.custom.details
  assign sustainability = product.metafields.custom.sustainability
  assign dimensions = product.metafields.custom.dimensions
  assign sizing = product.metafields.custom.sizing | metafield_tag
  assign materials = product.metafields.custom.materials_richtext | metafield_tag
  assign how_to_use = product.metafields.custom.how_to_use
  assign ingredients = product.metafields.custom.ingredients
  assign care = product.metafields.custom.care_richtext | metafield_tag
  assign shipping_returns = product.metafields.custom.shipping_returns
  assign badges = product.metafields.custom.badges
  assign gift_card_recipient_feature_active = false
  if product.gift_card?
    assign gift_card_recipient_feature_active = true
  endif
  assign wellness_stack_product = all_products['complete-wellness-stack']
  assign bundle_savings_onetime_line = ''
  assign bundle_savings_sub_line = ''
  assign stack_item_allergy = all_products['supplement-allergy']
  assign stack_item_digestive = all_products['supplement-digestivecare']
  assign stack_item_joint = all_products['supplement-hipandjoint']
  assign stack_item_skin = all_products['supplement-skinandcoat']
  assign stack_individual_sum_cents = 0
  if stack_item_allergy and stack_item_allergy.selected_or_first_available_variant
    assign stack_individual_sum_cents = stack_individual_sum_cents | plus: stack_item_allergy.selected_or_first_available_variant.price
  endif
  if stack_item_digestive and stack_item_digestive.selected_or_first_available_variant
    assign stack_individual_sum_cents = stack_individual_sum_cents | plus: stack_item_digestive.selected_or_first_available_variant.price
  endif
  if stack_item_joint and stack_item_joint.selected_or_first_available_variant
    assign stack_individual_sum_cents = stack_individual_sum_cents | plus: stack_item_joint.selected_or_first_available_variant.price
  endif
  if stack_item_skin and stack_item_skin.selected_or_first_available_variant
    assign stack_individual_sum_cents = stack_individual_sum_cents | plus: stack_item_skin.selected_or_first_available_variant.price
  endif
%}

{% render 'vite' with '/resources/js/pubsub.js' %}
{% render 'vite' with '/resources/js/product-form.js' %}

<article
  class="product {% if gift_card_recipient_feature_active %}-gift{% endif %}"
  id="MainProduct-{{ section.id }}"
  data-section="{{ section.id }}"
  data-url="{{ product.url }}"
>
  <div class="product-columns {% if product.images.size == 0 and product.handle != 'complete-wellness-stack' %}product-columns--no-images{% endif %}">
    {% if product.handle == 'complete-wellness-stack' %}
      <div class="product-column -images">
        <div class="bundle-image-grid">
          <a href="/products/supplement-allergy" class="bundle-image-item">
            <img src="https://cdn.shopify.com/s/files/1/0759/9515/2693/files/Maya_Allergy_Vet.jpg?v=1733098818&width=600" alt="MAYA Allergy Supplement" loading="lazy" width="300" height="375">
            <span class="bundle-image-label">Allergy</span>
          </a>
          <a href="/products/supplement-digestivecare" class="bundle-image-item">
            <img src="https://cdn.shopify.com/s/files/1/0759/9515/2693/files/Maya_Digestive_VET.jpg?v=1733098869&width=600" alt="MAYA Digestive Care Supplement" loading="lazy" width="300" height="375">
            <span class="bundle-image-label">Digestive</span>
          </a>
          <a href="/products/supplement-hipandjoint" class="bundle-image-item">
            <img src="https://cdn.shopify.com/s/files/1/0759/9515/2693/files/Maya_Joint_Vet.jpg?v=1733098928&width=600" alt="MAYA Joint Care Supplement" loading="lazy" width="300" height="375">
            <span class="bundle-image-label">Joint</span>
          </a>
          <a href="/products/supplement-skinandcoat" class="bundle-image-item">
            <img src="https://cdn.shopify.com/s/files/1/0759/9515/2693/files/MAYA_SKINCOAT_FRONT_2700_VET_2.jpg?v=1733098735&width=600" alt="MAYA Skin and Coat Supplement" loading="lazy" width="300" height="375">
            <span class="bundle-image-label">Skin & Coat</span>
          </a>
        </div>
      </div>
    {% elsif product.images.size > 0 %}
      <div class="product-column -images">
        {% render 'product-images' %}
      </div>
    {% endif %}
    <div class="product-column">
      <div class="product-column-inner">
        <div class="product-header">
          <h1 class="product-title">
            {{ product.title }}
            <span class="product-title-rating"></span>
          </h1>
          {%- comment -%} Description hidden - content rendered in accordion below {%- endcomment -%}

          {%- if product.handle == 'complete-wellness-stack' -%}
            {%- assign stack_onetime_cents = product.selected_or_first_available_variant.price -%}
            {%- assign stack_sub_cents = stack_onetime_cents | times: 80 | divided_by: 100 -%}
            {%- assign stack_save_onetime_cents = stack_individual_sum_cents | minus: stack_onetime_cents -%}
            {%- assign stack_save_sub_cents = stack_individual_sum_cents | minus: stack_sub_cents -%}
            {%- if stack_save_onetime_cents < 0 -%}{%- assign stack_save_onetime_cents = 0 -%}{%- endif -%}
            {%- if stack_save_sub_cents < 0 -%}{%- assign stack_save_sub_cents = 0 -%}{%- endif -%}
            <div class="bundle-includes">
              <p class="bundle-includes-title">What's included</p>
              <div class="bundle-includes-grid">
                {%- liquid
                  assign jar_allergy = 'https://cdn.shopify.com/s/files/1/0759/9515/2693/files/Maya_Allergy_Vet.jpg?v=1733098818&width=700'
                  assign jar_digestive = 'https://cdn.shopify.com/s/files/1/0759/9515/2693/files/Maya_Digestive_VET.jpg?v=1733098869&width=700'
                  assign jar_joint = 'https://cdn.shopify.com/s/files/1/0759/9515/2693/files/Maya_Joint_Vet.jpg?v=1733098928&width=700'
                  assign jar_skin = 'https://cdn.shopify.com/s/files/1/0759/9515/2693/files/MAYA_SKINCOAT_FRONT_2700_VET_2.jpg?v=1733098735&width=700'
                  if stack_item_allergy and stack_item_allergy.featured_image
                    assign jar_allergy = stack_item_allergy.featured_image | image_url: width: 700
                  endif
                  if stack_item_digestive and stack_item_digestive.featured_image
                    assign jar_digestive = stack_item_digestive.featured_image | image_url: width: 700
                  endif
                  if stack_item_joint and stack_item_joint.featured_image
                    assign jar_joint = stack_item_joint.featured_image | image_url: width: 700
                  endif
                  if stack_item_skin and stack_item_skin.featured_image
                    assign jar_skin = stack_item_skin.featured_image | image_url: width: 700
                  endif
                -%}
                <div class="bundle-includes-cell">
                  <a href="/products/supplement-allergy" class="bundle-includes-item">
                    <span class="bundle-includes-item-name">Allergy</span>
                    <span class="bundle-includes-item-concern">Itching, redness, seasonal sensitivity</span>
                    <span class="bundle-includes-item-price">{% if stack_item_allergy and stack_item_allergy.selected_or_first_available_variant %}{{ stack_item_allergy.selected_or_first_available_variant.price | money_without_trailing_zeros }}{% else %}—{% endif %} individually</span>
                  </a>
                  <div class="bundle-includes-hover-lightbox" aria-hidden="true">
                    <div class="bundle-includes-hover-lightbox__inner">
                      <img src="{{ jar_allergy }}" alt="{% if stack_item_allergy %}{{ stack_item_allergy.title | escape }}{% else %}MAYA Allergy supplement{% endif %}" loading="lazy" width="700" height="875" decoding="async">
                    </div>
                  </div>
                </div>
                <div class="bundle-includes-cell">
                  <a href="/products/supplement-digestivecare" class="bundle-includes-item">
                    <span class="bundle-includes-item-name">Digestive Care</span>
                    <span class="bundle-includes-item-concern">Gas, bloating, nutrient absorption</span>
                    <span class="bundle-includes-item-price">{% if stack_item_digestive and stack_item_digestive.selected_or_first_available_variant %}{{ stack_item_digestive.selected_or_first_available_variant.price | money_without_trailing_zeros }}{% else %}—{% endif %} individually</span>
                  </a>
                  <div class="bundle-includes-hover-lightbox" aria-hidden="true">
                    <div class="bundle-includes-hover-lightbox__inner">
                      <img src="{{ jar_digestive }}" alt="{% if stack_item_digestive %}{{ stack_item_digestive.title | escape }}{% else %}MAYA Digestive Care supplement{% endif %}" loading="lazy" width="700" height="875" decoding="async">
                    </div>
                  </div>
                </div>
                <div class="bundle-includes-cell">
                  <a href="/products/supplement-hipandjoint" class="bundle-includes-item">
                    <span class="bundle-includes-item-name">Joint Care</span>
                    <span class="bundle-includes-item-concern">Stiffness, mobility, cartilage</span>
                    <span class="bundle-includes-item-price">{% if stack_item_joint and stack_item_joint.selected_or_first_available_variant %}{{ stack_item_joint.selected_or_first_available_variant.price | money_without_trailing_zeros }}{% else %}—{% endif %} individually</span>
                  </a>
                  <div class="bundle-includes-hover-lightbox" aria-hidden="true">
                    <div class="bundle-includes-hover-lightbox__inner">
                      <img src="{{ jar_joint }}" alt="{% if stack_item_joint %}{{ stack_item_joint.title | escape }}{% else %}MAYA Joint Care supplement{% endif %}" loading="lazy" width="700" height="875" decoding="async">
                    </div>
                  </div>
                </div>
                <div class="bundle-includes-cell">
                  <a href="/products/supplement-skinandcoat" class="bundle-includes-item">
                    <span class="bundle-includes-item-name">Skin & Coat</span>
                    <span class="bundle-includes-item-concern">Shedding, dry skin, coat softness</span>
                    <span class="bundle-includes-item-price">{% if stack_item_skin and stack_item_skin.selected_or_first_available_variant %}{{ stack_item_skin.selected_or_first_available_variant.price | money_without_trailing_zeros }}{% else %}—{% endif %} individually</span>
                  </a>
                  <div class="bundle-includes-hover-lightbox" aria-hidden="true">
                    <div class="bundle-includes-hover-lightbox__inner">
                      <img src="{{ jar_skin }}" alt="{% if stack_item_skin %}{{ stack_item_skin.title | escape }}{% else %}MAYA Skin &amp; Coat supplement{% endif %}" loading="lazy" width="700" height="875" decoding="async">
                    </div>
                  </div>
                </div>
              </div>
              {%- capture bundle_savings_onetime_line -%}
Save {{ stack_save_onetime_cents | money_without_trailing_zeros }} vs buying individually ({{ stack_individual_sum_cents | money_without_trailing_zeros }} → {{ stack_onetime_cents | money_without_trailing_zeros }}) · {{ stack_onetime_cents | divided_by: 30 | money_without_trailing_zeros }}/day for complete coverage
              {%- endcapture -%}
              {%- capture bundle_savings_sub_line -%}
Save {{ stack_save_sub_cents | money_without_trailing_zeros }} vs buying individually ({{ stack_individual_sum_cents | money_without_trailing_zeros }} → {{ stack_sub_cents | money_without_trailing_zeros }}) · {{ stack_sub_cents | divided_by: 30 | money_without_trailing_zeros }}/day for complete coverage
              {%- endcapture -%}
              <p class="bundle-savings" id="bundle-savings-{{ section.id }}">{{ bundle_savings_onetime_line | strip }}</p>
            </div>
          {%- endif -%}
        </div>
        <div class="product-details">
          <product-form class="product-form">
            <div class="product-form-inner">
              {%- assign product_form_id = 'product-form-' | append: section.id -%}
              <div class="product-form-error product-form__error-message-wrapper" role="alert" hidden>
                <span class="product-form__error-message"></span>
              </div>
              {%- unless product.has_only_default_variant -%}
                <div class="product-variants">
                  <div data-section="{{ section.id }}" data-url="{{ product.url }}">
                    <div class="product-variants-inner">
                      {%- for option in product.options_with_values -%}
                        {% comment %} {% unless option.name == 'Color' %}{% endunless %} {% endcomment %}

                        <fieldset class="variant-select-wrapper" data-name="{{ option.name }}">
                          <span class="variant-select-value">{{ option.selected_value }}</span>
                          <select class="variant-select" name="{{ option.name }}">
                            <optgroup label="{{ option.name }}">
                              {%- for value in option.values -%}
                                <option
                                  value="{{ value | escape }}"
                                  form="{{ product_form_id }}"
                                  {% if option.selected_value == value %}
                                    selected
                                  {% endif %}
                                >
                                  {{ value }}
                                </option>
                              {%- endfor -%}
                            </optgroup>
                          </select>
                          <svg class="variant-select-chevron" viewBox="0 0 13 8">
                            <path d="m1 1 5.346 5.345L11.691 1"/>
                          </svg>
                        </fieldset>

                        {% comment %}
                          <fieldset class="variant-radios" data-name="{{ option.name }}">
                            <h3 class="variant-radios-legend">
                              <strong>{{ option.name }}</strong>:
                              <span class="variant-radios-value">{{ option.selected_value }}</span>
                            </h3>
                            <div class="variant-radios-items-outer">
                              <div class="variant-radios-items-wrapper">
                                <div class="variant-radios-items">
                                  {%- for value in option.values -%}
                                    <label class="variant-radios-item">
                                      <input
                                        type="radio"
                                        class="variant-radios-item-input"
                                        name="{{ option.name }}"
                                        value="{{ value | escape }}"
                                        form="{{ product_form_id }}"
                                        {% if option.selected_value == value %}
                                          checked
                                        {% endif %}
                                      >
                                      <span class="variant-radios-item-inner">
                                        {{ value }}
                                      </span>
                                    </label>
                                  {%- endfor -%}
                                </div>
                              </div>
                            </div>
                          </fieldset>
                        {% endcomment %}
                      {%- endfor -%}
                    </div>
                  </div>
                  <script type="application/json">
                    {{ product.variants | json }}
                  </script>
                </div>
              {%- endunless -%}

              {%- form 'product',
                product,
                id: product_form_id,
                class: 'form',
                novalidate: 'novalidate',
                data-type: 'add-to-cart-form'
              -%}
              {%- if product.selling_plan_groups.size > 0 -%}
                {%- assign selling_plan_group = product.selling_plan_groups.first -%}
                {%- assign selling_plan = selling_plan_group.selling_plans.first -%}
                {%- assign original_price = product.selected_or_first_available_variant.price -%}
                {%- assign sub_price = original_price | times: 80 | divided_by: 100 -%}
              {%- endif -%}
                <input
                  type="hidden"
                  name="id"
                  value="{{ product.selected_or_first_available_variant.id }}"
                  disabled
                >
                {%- if product.selling_plan_groups.size > 0 and product.metafields.custom.waitlist == blank -%}
                  <input type="hidden" name="selling_plan" value="">
                {%- endif -%}
                {%- if gift_card_recipient_feature_active -%}
                  {%- render 'gift-card-recipient-form', product: product, form: form, section: section -%}
                {%- endif -%}
                <div class="product-form-details">
                  <h1 class="product-form-details-title">{{ product.title }}</h1>
                </div>
                <div class="product-form-buttons">
                  {% if product.metafields.custom.waitlist %}
                    <button
                      type="button"
                      class="button product-buy-button product-waitlist-button"
                    >
                      <svg class="button-border">
                        <rect width="calc(100% - 2px)" height="calc(100% - 2px)" rx="6" />
                      </svg>
                      <span class="product-form-submit-text"> Join the waitlist </span>
                    </button>
                  {% else %}
                    <button
                      type="submit"
                      name="add"
                      class="button product-buy-button product-form-submit"
                      {% if product.selected_or_first_available_variant.available == false %}
                        disabled
                      {% endif %}
                    >
                      <svg class="button-border">
                        <rect width="calc(100% - 2px)" height="calc(100% - 2px)" rx="6" />
                      </svg>
                      <span class="product-form-submit-text">
                        {%- if product.selected_or_first_available_variant.available -%}
                          {% if product.metafields.custom.preorder %}
                            Pre-order
                          {% else %}
                            Add to cart
                          {% endif %}
                        {%- else -%}
                          Sold out
                        {%- endif -%}
                      </span>
                      <div class="loading-overlay__spinner hidden"></div>
                      <span class="product-price" id="price-{{ section.id }}">
                        {%- unless product.metafields.custom.email_for_price -%}
                          <span id="btn-price">{{- product.selected_or_first_available_variant.price | money_without_trailing_zeros -}}</span>
                          <del id="btn-compare" style="display:none;margin-left:0.3em;opacity:0.5">
                            {{- product.selected_or_first_available_variant.price | money_without_trailing_zeros -}}
                          </del>
                        {%- endunless -%}
                      </span>
                    </button>
                  {% endif %}
                </div>

                {%- if product.selling_plan_groups.size > 0 and product.metafields.custom.waitlist == blank -%}
                  {%- assign savings = original_price | minus: sub_price -%}
                  <div class="product-purchase-type" id="purchase-type-toggle">
                    <label class="purchase-option purchase-option--onetime" data-selected>
                      <input type="radio" name="purchase_type" value="onetime" checked>
                      <span class="purchase-option-label">One-time</span>
                      <span class="purchase-option-price">{{ original_price | money_without_trailing_zeros }}</span>
                    </label>
                    <label class="purchase-option purchase-option--sub">
                      <input type="radio" name="purchase_type" value="subscription">
                      <span class="purchase-option-label">Subscribe &middot; Save 20%</span>
                      <span class="purchase-option-price">{{ sub_price | money_without_trailing_zeros }}</span>
                      <span class="purchase-option-detail">Every 12 weeks &middot; Cancel anytime</span>
                    </label>
                  </div>
                  <script>
                    (function(){
                      var toggle = document.getElementById('purchase-type-toggle');
                      if(!toggle) return;
                      var radios = toggle.querySelectorAll('input[type=radio]');
                      var sellingPlanInput = document.querySelector('[name=selling_plan]');
                      var btnPrice = document.getElementById('btn-price');
                      var btnCompare = document.getElementById('btn-compare');
                      var bundleSavings = document.getElementById('bundle-savings-{{ section.id }}');
                      var bundleLineOnetime = {{ bundle_savings_onetime_line | strip | json }};
                      var bundleLineSub = {{ bundle_savings_sub_line | strip | json }};
                      radios.forEach(function(radio){
                        radio.addEventListener('change', function(){
                          toggle.querySelectorAll('.purchase-option').forEach(function(opt){
                            opt.removeAttribute('data-selected');
                          });
                          this.closest('.purchase-option').setAttribute('data-selected','');
                          if(this.value === 'subscription'){
                            if(sellingPlanInput) sellingPlanInput.value = '{{ selling_plan.id }}';
                            if(btnPrice) btnPrice.innerHTML = '{{ sub_price | money_without_trailing_zeros }}';
                            if(btnCompare) btnCompare.style.display = 'inline';
                            if(bundleSavings && bundleLineSub) bundleSavings.textContent = bundleLineSub;
                          } else {
                            if(sellingPlanInput) sellingPlanInput.value = '';
                            if(btnPrice) btnPrice.innerHTML = '{{ original_price | money_without_trailing_zeros }}';
                            if(btnCompare) btnCompare.style.display = 'none';
                            if(bundleSavings && bundleLineOnetime) bundleSavings.textContent = bundleLineOnetime;
                          }
                        });
                      });
                    })();
                  </script>
                {%- endif -%}

              {%- endform -%}

              {%- comment -%} Hide any old or app-injected selling plan UI {%- endcomment -%}
              <style>
                .shopify-subscription-widget,
                [id*="shopify-subscription"],
                .selling-plan-widget,
                shopify-selling-plan-widget,
                .shopify-app-block [data-shopify-selling-plan],
                .product-selling-plan {
                  display: none !important;
                }
              </style>

              {%- comment -%} Trust stack + price-per-day {%- endcomment -%}
              {%- if product.type == 'Supplement Chew' -%}
                <p class="product-per-day">Less than {{ product.price | divided_by: 30 | money_without_trailing_zeros }} per day &middot; 30-day supply</p>
              {%- endif -%}
              <div class="product-trust-stack">
                {%- if product.type == 'Supplement Chew' -%}
                  <p>Vet-formulated &middot; USDA certified &middot; Made in Los Angeles</p>
                  <p>30-day guarantee &middot; Free shipping over $100</p>
                {%- else -%}
                  <p>Made in Los Angeles &middot; 30-day guarantee</p>
                  <p>Free shipping over $100</p>
                {%- endif -%}
              </div>

              {%- if product.type == 'Supplement Chew' -%}
                <div class="product-why-different">
                  <p class="product-why-different-title">Approach</p>
                  <ul>
                    <li>No fillers, binders, or artificial flavoring</li>
                    <li>Produced in small batches in Los Angeles</li>
                    <li>Each ingredient sourced and tested individually</li>
                    <li>Formulated for function, not marketing</li>
                  </ul>
                </div>
                <div class="product-why-different">
                  <p class="product-why-different-title">What to expect</p>
                  <ul>
                    <li>This is not an instant fix</li>
                    <li>Visible improvement typically within 2–4 weeks</li>
                    <li>Consistency is required for meaningful results</li>
                    <li>Effects compound with continued daily use</li>
                  </ul>
                </div>
                <div class="product-why-different">
                  <p class="product-why-different-title">What we don't include</p>
                  <ul>
                    <li>No artificial flavors or colors</li>
                    <li>No grain-based fillers</li>
                    <li>No synthetic preservatives</li>
                    <li>No ingredients without a functional purpose</li>
                  </ul>
                </div>
                <div class="product-why-different">
                  <p class="product-why-different-title">Why this exists</p>
                  <p class="product-why-different-text">Most supplement brands optimize for shelf price and label claims. We saw dogs with real issues being given products full of fillers and underdosed ingredients. MAYA exists because we believe the standard should be higher — and that the difference should be measurable.</p>
                </div>
                <p class="product-usage-signal">Used daily by owners managing allergies, digestion, and joint health.</p>
              {%- endif -%}

              {%- if product.handle == 'complete-wellness-stack' -%}
                <div class="product-bundle-info">
                  <div class="product-why-different">
                    <p class="product-why-different-title">Four supplements. One routine.</p>
                    <p class="product-why-different-text">The Complete Wellness Stack covers allergy, digestion, joint, and skin & coat support. Each formula addresses a specific condition. No overlap. No filler.</p>
                  </div>
                  <div class="product-why-different">
                    <p class="product-why-different-title">What's included</p>
                    <ul>
                      <li>Allergy — seasonal scratching, red skin, hot spots</li>
                      <li>Digestive Care — gas, bloating, loose stool</li>
                      <li>Joint Care — stiffness, reluctance to jump</li>
                      <li>Skin & Coat — shedding, dry skin, dull coat</li>
                    </ul>
                  </div>
                  <div class="product-why-different">
                    <p class="product-why-different-title">Why the stack</p>
                    <p class="product-why-different-text">Most dogs benefit from more than one formula. Allergy and skin issues overlap. Digestion affects coat health. Joint support matters before you see the limp. The stack covers the full picture.</p>
                  </div>
                  <div class="product-why-different">
                    <p class="product-why-different-title">Stack savings</p>
                    <p class="product-why-different-text">One-time {{ stack_onetime_cents | money_without_trailing_zeros }} for all four (save {{ stack_save_onetime_cents | money_without_trailing_zeros }} vs {{ stack_individual_sum_cents | money_without_trailing_zeros }} individually){% if product.selling_plan_groups.size > 0 %}, or {{ stack_sub_cents | money_without_trailing_zeros }} on subscribe &amp; save (save {{ stack_save_sub_cents | money_without_trailing_zeros }}){% endif %}. Each supplement is a full 30-day supply.</p>
                  </div>
                  <div class="product-why-different">
                    <p class="product-why-different-title">Approach</p>
                    <ul>
                      <li>No fillers, binders, or artificial flavoring</li>
                      <li>Produced in small batches in Los Angeles</li>
                      <li>Each ingredient sourced and tested individually</li>
                      <li>Vet-formulated. USDA certified.</li>
                    </ul>
                  </div>
                </div>
              {%- endif -%}
            </div>
          </product-form>

          <div class="product-info">
            <div class="product-info-accordion">
              {% if details != blank %}
                <div class="product-info-row">
                  <h3 class="product-info-title">Details</h3>
                  <div class="product-info-value">
                    <div class="product-info-value-inner">
