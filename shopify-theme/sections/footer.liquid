<h2 class="footer-newsletter-title">Join the community.</h2>
<form
  class="footer-newsletter"
  action="https://officeofmaya.us22.list-manage.com/subscribe/post-json?u=30fbe462ad0fc59a89b1a06a6&id=0c6bb8e4ec&f_id=0096cfe1f0"
  accept-charset="UTF-8"
  method="get"
>
  <input class="footer-newsletter-input" type="email" name="EMAIL" placeholder="Email address" required>
  <button class="footer-newsletter-submit" type="submit"><span>Join the community</span> <i>→</i></button>
</form>

<div class="footer-end">
  <p class="footer-copyright">
    © {{ 'now' | date: '%Y' }}
    {{ shop.name | link_to: routes.root_url }}
  </p>
  <p>{{ section.settings.footer_text }}</p>
  <a class="footer-credits" href="https://www.officeb.org" target="_blank">Credits</a>

  <ul class="footer-menu">
    {% for link in linklists.footer.links %}
      <li>
        <a class="footer-menu-link" href="{{ link.url }}">{{ link.title }}</a>
      </li>
    {% endfor %}
  </ul>
</div>

{% schema %}
{
  "name": "Footer",
  "tag": "footer",
  "class": "footer",
  "settings": [
    {
      "type": "text",
      "id": "footer_text",
      "label": "Footer text"
    }
  ]
}
{% endschema %}
