{% comment %}
  MAYA Product Quiz — 5 questions, scores across 4 formulas, emails recommendation
  via MailerLite form endpoint. Uses existing MAYA-FORM ID 185492455689291593.

  This page is self-contained — all styles and JS are inline so it works without
  theme modifications.
{% endcomment %}

<style>
  .maya-quiz {
    background: #ffffff;
    min-height: 80vh;
    padding: 4rem var(--side-padding, 1.5rem);
    font-family: inherit;
    color: #1a1a1a;
  }
  .mq-container { max-width: 640px; margin: 0 auto; }

  /* Progress bar */
  .mq-progress {
    height: 2px;
    background: rgba(0,0,0,0.08);
    margin-bottom: 3rem;
    overflow: hidden;
  }
  .mq-progress-fill {
    height: 100%;
    background: #1a1a1a;
    transition: width 300ms ease;
    width: 0;
  }

  /* Typography */
  .mq-eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    opacity: 0.5;
    margin: 0 0 0.75rem 0;
    text-transform: uppercase;
  }
  .mq-prompt {
    font-size: 1.75rem;
    line-height: 1.2;
    font-weight: 400;
    margin: 0 0 0.75rem 0;
  }
  .mq-subtitle {
    opacity: 0.6;
    margin: 0 0 2rem 0;
    line-height: 1.5;
    font-size: 1rem;
  }

  /* Option buttons */
  .mq-options {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }
  .mq-option {
    text-align: left;
    padding: 1.25rem 1.5rem;
    border: 1px dashed rgba(0,0,0,0.25);
    background: transparent;
    cursor: pointer;
    font: inherit;
    font-size: 1rem;
    color: #1a1a1a;
    transition: all 150ms ease;
  }
  .mq-option:hover {
    border-color: rgba(0,0,0,0.6);
    background: rgba(0,0,0,0.02);
  }
  .mq-option.selected {
    border-color: #1a1a1a;
    background: #1a1a1a;
    color: #fdfbf7;
  }
  .mq-back {
    background: none;
    border: none;
    cursor: pointer;
    font: inherit;
    font-size: 0.875rem;
    opacity: 0.5;
    padding: 0.5rem 0;
    color: #1a1a1a;
  }
  .mq-back:hover { opacity: 1; }

  /* Email form */
  .mq-inputs {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin: 1.5rem 0 1rem;
  }
  .mq-input {
    padding: 1rem 1.25rem;
    border: 1px dashed rgba(0,0,0,0.25);
    background: transparent;
    font: inherit;
    font-size: 1rem;
    color: #1a1a1a;
    font-family: inherit;
  }
  .mq-input:focus {
    outline: none;
    border-color: #1a1a1a;
    border-style: solid;
  }
  .mq-btn-primary {
    padding: 1rem 1.5rem;
    background: #1a1a1a;
    color: #fdfbf7;
    border: none;
    cursor: pointer;
    font: inherit;
    font-size: 0.875rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    transition: opacity 150ms ease;
  }
  .mq-btn-primary:hover:not(:disabled) { opacity: 0.85; }
  .mq-btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }
  .mq-btn-ghost {
    padding: 0.75rem 1rem;
    background: transparent;
    border: 1px dashed rgba(0,0,0,0.3);
    cursor: pointer;
    font: inherit;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #1a1a1a;
    text-decoration: none;
    display: inline-block;
  }
  .mq-btn-ghost:hover {
    background: #1a1a1a;
    color: #fdfbf7;
  }
  .mq-fine {
    font-size: 0.75rem;
    opacity: 0.5;
    margin: 1rem 0 0 0;
  }

  /* ---------- Results ---------- */
  /* Layout: single editorial column, generous whitespace, no card chrome */
  .maya-quiz.-results { padding-top: 6rem; padding-bottom: 6rem; }
  .mq-results { max-width: 720px; margin: 0 auto; }

  .mq-results-eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    opacity: 0.5;
    margin: 0 0 1.5rem 0;
  }
  .mq-results-title {
    font-size: clamp(2.25rem, 6vw, 3.5rem);
    font-weight: 400;
    line-height: 1.05;
    margin: 0 0 1rem 0;
    letter-spacing: -0.01em;
  }
  .mq-results-subtitle {
    font-size: 1rem;
    line-height: 1.5;
    opacity: 0.6;
    margin: 0 0 4rem 0;
    max-width: 36ch;
  }

  /* Hero product feature */
  .mq-hero {
    margin: 0 0 4rem 0;
  }
  .mq-hero-image-wrap {
    width: 100%;
    aspect-ratio: 4 / 3;
    background: #ffffff;
    overflow: hidden;
    margin-bottom: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .mq-hero-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
  .mq-hero-meta {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .mq-hero-label {
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    opacity: 0.55;
    margin: 0;
  }
  .mq-hero-title {
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 400;
    line-height: 1.15;
    margin: 0;
    letter-spacing: -0.01em;
  }
  .mq-hero-price {
    font-size: 1rem;
    margin: 0.25rem 0 1.75rem 0;
    opacity: 0.75;
  }

  /* Site-style button with animated SVG border (matches theme `.button`) */
  .mq-button {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    min-width: 10.7rem;
    height: 3.57rem;
    padding: 0 1.5rem;
    position: relative;
    -webkit-user-select: none;
    user-select: none;
    background: transparent;
    color: #1a1a1a;
    border: none;
    cursor: pointer;
    font: inherit;
    font-size: 1rem;
    letter-spacing: 0.01em;
    text-decoration: none;
    text-align: center;
  }
  .mq-button-border {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    overflow: visible;
  }
  .mq-button-border rect {
    fill: none;
    stroke: #1a1a1a;
    stroke-width: 1px;
    stroke-dasharray: 800;
    stroke-dashoffset: 800;
    transition: stroke-dashoffset 600ms ease;
  }
  .mq-button:hover .mq-button-border rect,
  .mq-button:focus-visible .mq-button-border rect {
    stroke-dashoffset: 0;
  }

  /* Editorial divider between sections */
  .mq-rule {
    border: 0;
    border-top: 1px solid rgba(0,0,0,0.12);
    margin: 4rem 0;
  }

  /* Discount code — typography-only, no dark box */
  .mq-code {
    text-align: center;
    margin: 0 0 4rem 0;
  }
  .mq-code-label {
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    opacity: 0.5;
    margin: 0 0 0.75rem 0;
  }
  .mq-code-value {
    font-size: clamp(2rem, 5vw, 2.75rem);
    letter-spacing: 0.18em;
    margin: 0 0 1rem 0;
    font-weight: 400;
  }
  .mq-code-note {
    font-size: 0.8rem;
    opacity: 0.55;
    margin: 0;
    line-height: 1.5;
    overflow-wrap: anywhere; /* prevent layout overflow on very long emails */
  }
  .mq-code-note strong { font-weight: 400; opacity: 0.9; }

  /* Footer CTA */
  .mq-footer {
    text-align: center;
    margin-top: 1rem;
  }
  .mq-footer-link {
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.55;
    color: #1a1a1a;
    text-decoration: none;
    border-bottom: 1px solid rgba(0,0,0,0.25);
    padding-bottom: 0.15rem;
    transition: opacity 150ms ease, border-color 150ms ease;
  }
  .mq-footer-link:hover { opacity: 1; border-color: #1a1a1a; }
</style>

<div class="maya-quiz" id="maya-quiz-root">
  <div class="mq-container">

    <!-- Progress bar -->
    <div class="mq-progress" id="mq-progress">
      <div class="mq-progress-fill" id="mq-progress-fill"></div>
    </div>

    <!-- Question screens (populated by JS) -->
    <div id="mq-content"></div>

  </div>
</div>

<script>
(function() {
  'use strict';

  // ---------- Configuration ----------
  // Quiz submissions POST to the MAYA Next.js API (not directly to
  // MailerLite's JSONP form endpoint) so we can pass status="active" and
  // bypass the account-wide double opt-in confirmation email — that email
  // is sent from "San Bernardino Tax Sales" because the MailerLite account
  // is shared across multiple brands. The Next.js handler subscribes the
  // user server-side using MAILERLITE_API_KEY, then the active
  // "MAYA - Quiz Welcome + 10% Off" automation sends the welcome email.
  //
  // The MAYA Next.js app is hosted on Vercel (officeofmaya.com is the
  // Shopify storefront — different system). Production alias verified
  // 2026-04-30 with `vercel get_project` → "maya-azure-pi.vercel.app".
  var QUIZ_SUBMIT_URL = 'https://maya-azure-pi.vercel.app/api/quiz-submit';

  // ---------- Products (pulled live from Shopify product metadata) ----------
  // These product handles must exist in the store.
  var PRODUCTS = {
    allergy: {
      handle: 'supplement-allergy',
      title: 'Allergy Supplement',
      image: null
    },
    digestive: {
      handle: 'supplement-digestive',
      title: 'Digestive Care Supplement',
      image: null
    },
    joint: {
      handle: 'supplement-joint',
      title: 'Joint Care Supplement',
      image: null
    },
    skin_coat: {
      handle: 'supplement-skin-coat',
      title: 'Skin & Coat Supplement',
      image: null
    }
  };

  {% comment %} Hydrate PRODUCTS with live Shopify data where handles match {% endcomment %}
  {% comment %}
    Hydrate PRODUCTS with live Shopify data. We use product.images.first
    (the bottle render — the first image in admin, e.g. Maya_Joint_1.png)
    rather than featured_image, and pre-format the price with Shopify's
    money_without_trailing_zeros filter so it matches the storefront exactly.
  {% endcomment %}
  {% for product in collections.all.products limit: 50 %}
    {% assign h = product.handle %}
    {% assign img = product.images.first | default: product.featured_image %}
    {% assign price_str = product.price_min | money_without_trailing_zeros %}
    {% if h contains 'allerg' %}
      PRODUCTS.allergy = {
        handle: {{ product.handle | json }},
        title: {{ product.title | json }},
        image: {{ img | img_url: '800x' | prepend: 'https:' | json }},
        price: {{ price_str | json }}
      };
    {% elsif h contains 'digest' or h contains 'gut' %}
      PRODUCTS.digestive = {
        handle: {{ product.handle | json }},
        title: {{ product.title | json }},
        image: {{ img | img_url: '800x' | prepend: 'https:' | json }},
        price: {{ price_str | json }}
      };
    {% elsif h contains 'joint' or h contains 'mobility' %}
      PRODUCTS.joint = {
        handle: {{ product.handle | json }},
        title: {{ product.title | json }},
        image: {{ img | img_url: '800x' | prepend: 'https:' | json }},
        price: {{ price_str | json }}
      };
    {% elsif h contains 'skin' or h contains 'coat' or h contains 'fur' %}
      PRODUCTS.skin_coat = {
        handle: {{ product.handle | json }},
        title: {{ product.title | json }},
        image: {{ img | img_url: '800x' | prepend: 'https:' | json }},
        price: {{ price_str | json }}
      };
    {% endif %}
  {% endfor %}

  // ---------- Questions ----------
  var QUESTIONS = [
    {
      id: 'age',
      prompt: "How old is your dog?",
      options: [
        { label: "Puppy (under 1 year)", scores: { digestive: 2, skin_coat: 1 } },
        { label: "Adult (1-7 years)", scores: { skin_coat: 1, allergy: 1 } },
        { label: "Senior (7+ years)", scores: { joint: 3, skin_coat: 1 } }
      ]
    },
    {
      id: 'breed',
      prompt: "What kind of dog do you have?",
      subtitle: "We use this to tailor the recommendation — breeds have different tendencies.",
      options: [
        { label: "Flat-faced (Frenchie, Pug, Bulldog)", scores: { allergy: 3, skin_coat: 2 } },
        { label: "Large breed (Golden, Lab, Shepherd)", scores: { joint: 3, skin_coat: 1 } },
        { label: "Small breed (Chihuahua, Dachshund)", scores: { joint: 2, skin_coat: 1 } },
        { label: "Mixed / Other", scores: { allergy: 1, digestive: 1, skin_coat: 1 } }
      ]
    },
    {
      id: 'concerns',
      prompt: "What's your dog's biggest issue right now?",
      subtitle: "Pick the one that's bothering them most.",
      options: [
        { label: "Itching, scratching, hot spots", scores: { allergy: 4, skin_coat: 2 } },
        { label: "Upset stomach, gas, loose stool", scores: { digestive: 4 } },
        { label: "Stiff joints, slow on walks", scores: { joint: 4 } },
        { label: "Dull coat, excessive shedding", scores: { skin_coat: 4 } },
        { label: "Nothing major — preventive care", scores: { allergy: 1, digestive: 1, joint: 1, skin_coat: 1 } }
      ]
    },
    {
      id: 'diet',
      prompt: "What do you feed your dog?",
      options: [
        { label: "Kibble", scores: { digestive: 2, skin_coat: 1 } },
        { label: "Fresh or raw", scores: { skin_coat: 1 } },
        { label: "Home-cooked", scores: { digestive: 1, skin_coat: 1 } },
        { label: "A mix of everything", scores: { digestive: 1 } }
      ]
    },
    {
      id: 'activity',
      prompt: "How active is your dog?",
      options: [
        { label: "Very active — hikes, runs, agility", scores: { joint: 3, skin_coat: 1 } },
        { label: "Moderate — daily walks", scores: { joint: 1, allergy: 1 } },
        { label: "Low — short walks, lots of naps", scores: { joint: 2, digestive: 1 } }
      ]
    }
  ];

  var FORMULA_LABEL = {
    allergy: 'Allergy',
    digestive: 'Digestive Care',
    joint: 'Joint Care',
    skin_coat: 'Skin & Coat'
  };

  // ---------- State ----------
  var state = {
    step: 0,
    answers: {},
    scores: { allergy: 0, digestive: 0, joint: 0, skin_coat: 0 },
    email: '',
    dogName: ''
  };

  var root = document.getElementById('mq-content');
  var progressFill = document.getElementById('mq-progress-fill');

  var totalSteps = QUESTIONS.length + 1; // +1 for email gate

  // ---------- Helpers ----------
  function escapeHtml(s) {
    return String(s).replace(/[&<>"']/g, function(c) {
      return { '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' }[c];
    });
  }

  function formatPrice(price) {
    // Price comes from Shopify as a pre-formatted string (money_without_trailing_zeros)
    // e.g. "$76", "$48.99". For backward-compat with raw cents, also handle numbers.
    if (!price && price !== 0) return '';
    if (typeof price === 'number') {
      // Legacy fallback: treat as cents, preserve cents in output
      var d = price / 100;
      return '$' + (d % 1 === 0 ? d.toFixed(0) : d.toFixed(2));
    }
    return String(price);
  }

  function updateProgress() {
    var pct = Math.round((state.step / totalSteps) * 100);
    progressFill.style.width = pct + '%';
  }

  // ---------- Render ----------
  function render() {
    updateProgress();

    if (state.step < QUESTIONS.length) {
      renderQuestion();
    } else if (state.step === QUESTIONS.length) {
      renderEmailGate();
    } else {
      renderResults();
    }
  }

  function renderQuestion() {
    var q = QUESTIONS[state.step];
    var html = '';
    html += '<div>';
    html += '  <p class="mq-eyebrow">Question ' + (state.step + 1) + ' of ' + QUESTIONS.length + '</p>';
    html += '  <h1 class="mq-prompt">' + escapeHtml(q.prompt) + '</h1>';
    if (q.subtitle) html += '  <p class="mq-subtitle">' + escapeHtml(q.subtitle) + '</p>';
    html += '  <div class="mq-options">';
    q.options.forEach(function(opt, i) {
      html += '    <button type="button" class="mq-option" data-step="' + state.step + '" data-opt="' + i + '">' +
              escapeHtml(opt.label) + '</button>';
    });
    html += '  </div>';
    if (state.step > 0) {
      html += '  <button type="button" class="mq-back" id="mq-back">&larr; Back</button>';
    }
    html += '</div>';
    root.innerHTML = html;

    // Wire up options
    root.querySelectorAll('.mq-option').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var stepIdx = parseInt(btn.getAttribute('data-step'), 10);
        var optIdx = parseInt(btn.getAttribute('data-opt'), 10);
        handleAnswer(stepIdx, optIdx);
      });
    });
    var back = document.getElementById('mq-back');
    if (back) back.addEventListener('click', function() {
      state.step = Math.max(0, state.step - 1);
      render();
    });
  }

  function renderEmailGate() {
    var html = '';
    html += '<form id="mq-email-form">';
    html += '  <p class="mq-eyebrow">Almost done</p>';
    html += '  <h1 class="mq-prompt">Where should we send the results?</h1>';
    html += '  <p class="mq-subtitle">We\'ll email your personalized recommendation, plus a 10% off code for your first order.</p>';
    html += '  <div class="mq-inputs">';
    html += '    <input class="mq-input" type="text" id="mq-dog-name" placeholder="Your dog\'s name (optional)">';
    html += '    <input class="mq-input" type="email" id="mq-email" placeholder="Your email" required>';
    html += '    <button type="submit" class="mq-btn-primary" id="mq-submit">See my recommendation</button>';
    html += '  </div>';
    html += '  <p class="mq-fine">We\'ll never share your email. Unsubscribe any time.</p>';
    html += '</form>';
    root.innerHTML = html;

    document.getElementById('mq-email-form').addEventListener('submit', function(e) {
      e.preventDefault();
      state.email = document.getElementById('mq-email').value.trim();
      state.dogName = document.getElementById('mq-dog-name').value.trim();
      if (!state.email) return;
      var btn = document.getElementById('mq-submit');
      btn.disabled = true;
      btn.textContent = 'Submitting...';
      submitToMailerLite().then(function() {
        state.step = totalSteps;
        render();
      });
    });
  }

  function renderResults() {
    var topFormula = Object.keys(state.scores).sort(function(a, b) {
      return state.scores[b] - state.scores[a];
    })[0];
    var product = PRODUCTS[topFormula];
    var label = FORMULA_LABEL[topFormula] || topFormula;

    // Editorial signature button used on the rest of the site — animated
    // SVG border drawing on hover. Returns the button as an <a>.
    function buttonLink(href, text) {
      return '<a href="' + escapeHtml(href) + '" class="mq-button">' +
             '<span>' + escapeHtml(text) + '</span>' +
             '<svg class="mq-button-border" preserveAspectRatio="none">' +
             '<rect x="0.5" y="0.5" width="calc(100% - 1px)" height="calc(100% - 1px)" rx="5" ry="5" />' +
             '</svg>' +
             '</a>';
    }

    // Switch the page wrapper into "results" mode for top/bottom padding.
    var wrapper = document.querySelector('.maya-quiz');
    if (wrapper) wrapper.classList.add('-results');
    // Hide the progress bar on the final screen.
    var progress = document.getElementById('mq-progress');
    if (progress) progress.style.display = 'none';

    var title = state.dogName
      ? (escapeHtml(state.dogName) + "'s formula")
      : "Your dog's formula";

    var html = '';
    html += '<div class="mq-results">';
    html += '  <p class="mq-results-eyebrow">Your recommendation</p>';
    html += '  <h1 class="mq-results-title">' + title + '</h1>';
    html += '  <p class="mq-results-subtitle">Based on your answers, this is the formula we\'d start with.</p>';

    if (product) {
      html += '  <div class="mq-hero">';
      if (product.image) {
        html += '    <div class="mq-hero-image-wrap">';
        html += '      <img src="' + escapeHtml(product.image) + '" alt="' + escapeHtml(product.title) + '">';
        html += '    </div>';
      }
      html += '    <div class="mq-hero-meta">';
      html += '      <p class="mq-hero-label">Best match &mdash; ' + escapeHtml(label) + '</p>';
      html += '      <h2 class="mq-hero-title">' + escapeHtml(product.title) + '</h2>';
      if (product.price) {
        html += '      <p class="mq-hero-price">' + formatPrice(product.price) + '</p>';
      }
      html += '      <div>' + buttonLink('/products/' + product.handle, 'Shop ' + label) + '</div>';
      html += '    </div>';
      html += '  </div>';
    }

    html += '  <hr class="mq-rule">';

    html += '  <div class="mq-code">';
    html += '    <p class="mq-code-label">Your 10% off code</p>';
    html += '    <p class="mq-code-value">QUIZ10</p>';
    html += '    <p class="mq-code-note">We emailed it to <strong>' + escapeHtml(state.email) + '</strong>. Check your inbox.</p>';
    html += '  </div>';

    html += '  <p class="mq-footer">';
    html += '    <a href="/collections/all" class="mq-footer-link">Shop all MAYA</a>';
    html += '  </p>';
    html += '</div>';

    root.innerHTML = html;
  }

  // ---------- Logic ----------
  function handleAnswer(stepIdx, optIdx) {
    var q = QUESTIONS[stepIdx];
    var opt = q.options[optIdx];
    state.answers[q.id] = opt.label;
    for (var f in opt.scores) {
      if (Object.prototype.hasOwnProperty.call(opt.scores, f)) {
        state.scores[f] = (state.scores[f] || 0) + opt.scores[f];
      }
    }
    // Highlight selected briefly, then advance
    var btn = root.querySelector('.mq-option[data-step="' + stepIdx + '"][data-opt="' + optIdx + '"]');
    if (btn) btn.classList.add('selected');
    setTimeout(function() {
      state.step = stepIdx + 1;
      render();
    }, 180);
  }

  function submitToMailerLite() {
    // Posts to the MAYA Next.js API which subscribes the user to MailerLite
    // server-side with status="active" (no double-opt-in confirmation email).
    return fetch(QUIZ_SUBMIT_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        email: state.email,
        dogName: state.dogName,
        answers: state.answers,
        scores: state.scores
      }),
      mode: 'cors'
    }).catch(function(err) {
      // Non-blocking — still show results if submit fails
      console.error('[maya-quiz] quiz-submit failed', err);
    });
  }

  // ---------- Init ----------
  render();
})();
</script>
