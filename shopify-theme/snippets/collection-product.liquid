<div class="collection-product">
  <a class="collection-product-link" href="{{ product.url }}">
    <svg class="button-border">
      <rect width="calc(100% - 2px)" height="calc(100% - 2px)" rx="5" />
    </svg>
    <div class="collection-product-image-container">
      {% if product.metafields.custom.plp_image %}
        {% assign media = product.metafields.custom.plp_image %}
      {% endif %}
      {% if media %}
        {% if media.media_type == 'video' %}
          {{
            media
            | video_tag:
              playsinline: true,
              controls: false,
              autoplay: true,
              muted: true,
              loop: true,
              class: 'collection-product-image'
          }}
        {% else %}
          {% assign image = media %}
          <img
            class="collection-product-image"
            width="{{ image.width }}"
            height="{{ image.height }}"
            srcset="{{ image | image_url: width: 200 }} 200w, {{ image | image_url: width: 300 }} 300w, {{ image | image_url: width: 400 }} 400w, {{ image | image_url: width: 500 }} 500w, {{ image | image_url: width: 600 }} 600w, {{ image | image_url: width: 600 }} 600w, {{ image | image_url: width: 700 }} 700w, {{ image | image_url: width: 800 }} 800w, {{ image | image_url: width: 900 }} 900w, {{ image | image_url: width: 1000 }} 1000w, {{ image | image_url: width: 1200 }} 1200w, {{ image | image_url: width: 1400 }} 1400w, {{ image | image_url: width: 1800 }} 1800w, {{ image | image_url: width: 2200 }} 2200w"
            sizes="{{ image_sizes }}"
            src="{{ image | image_url: width: 600 }}"
            alt="{{ image.alt | escape }}"
            loading="lazy"
          >
        {% endif %}
      {% else %}

      {% endif %}
    </div>
    <div class="collection-product-data">
      <div class="collection-details-title">{{ product.title }}</div>
      <div class="collection-details-price">
        {{ product.price | money_without_trailing_zeros }}
        {% if product.compare_at_price %}
          <del>
            {{ product.compare_at_price | money_without_trailing_zeros }}
          </del>
        {% endif %}
      </div>
      <div class="collection-details-category">{{ product.collections[0].title }}</div>
    </div>
  </a>
</div>
