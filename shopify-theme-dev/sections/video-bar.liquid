{% assign image = section.settings.image %}

<div class="video-bar-box">
  <a class="video-bar-box-link" href="{{ section.settings.video_url }}">
    <img
      width="{{ image.width }}"
      height="{{ image.height }}"
      class="video-bar-box-image"
      src="{{ image | image_url: width: 200 }}"
      srcset="{{ image | image_url: width: 300 }} 300w, {{ image | image_url: width: 400 }} 400w, {{ image | image_url: width: 500 }} 500w, {{ image | image_url: width: 600 }} 600w, {{ image | image_url: width: 700 }} 700w, {{ image | image_url: width: 800 }} 800w, {{ image | image_url: width: 900 }} 900w, {{ image | image_url: width: 1000 }} 1000w"
      sizes="(min-width: 1024px) 6vw, 50vw"
      alt="{{ image.alt | escape }}"
      loading="lazy"
    >
    <div class="video-bar-box-text">
      <h3 class="video-bar-box-title">{{ section.settings.title }}</h3>
      <p class="video-bar-box-desc">{{ section.settings.desc }}</p>
    </div>
    <svg class="button-border">
      <rect width="calc(100% - 2px)" height="calc(100% - 2px)" rx="5" />
    </svg>
  </a>
  <button class="video-bar-box-close" type="button">(Close)</button>
</div>

<div class="video-bar-popup">
  <div class="video-bar-popup-overlay"></div>
  <div class="video-bar-popup-box">
    <div
      class="video-bar-popup-player"
      data-plyr-provider="{{ section.settings.video_url.type }}"
      data-plyr-embed-id="{{ section.settings.video_url.id }}"
    ></div>
  </div>
</div>

{% schema %}
{
  "name": "Video bar",
  "tag": "div",
  "class": "video-bar",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "textarea",
      "id": "desc",
      "label": "Description"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "label": "Video URL",
      "accept": ["youtube", "vimeo"]
    }
  ]
}
{% endschema %}
