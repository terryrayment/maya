{%- comment -%}
  Subscribe incentive — compact inline section.
{%- endcomment -%}

<div class="sub-incentive">
  <div class="sub-incentive-inner">
    <div class="sub-incentive-left">
      <h2 class="sub-incentive-title">Subscribe & save 20%</h2>
      <p class="sub-incentive-desc">Every 12 weeks. Free shipping over $100. Cancel anytime. No fees.</p>
    </div>
    <div class="sub-incentive-right">
      <a href="/collections/wellness" class="sub-incentive-link">
        <svg class="button-border"><rect width="calc(100% - 2px)" height="calc(100% - 2px)" rx="5" /></svg>
        Shop supplements
      </a>
    </div>
  </div>
</div>

<style>
  .sub-incentive {
    padding: 2rem var(--side-padding);
    position: relative;
    z-index: 10;
    background: var(--bg, #fdfbf7);
    background-image: linear-gradient(to right, #000 50%, transparent 50%);
    background-size: 4px 1px;
    background-repeat: repeat-x;
    background-position: top;
  }
  .sub-incentive-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .sub-incentive-title {
    font-size: 1em;
    letter-spacing: 0.04em;
    line-height: 1.2;
    margin-bottom: 0.3rem;
  }
  .sub-incentive-desc {
    font-size: 0.7em;
    letter-spacing: 0.03em;
    opacity: 0.4;
    line-height: 1.5;
  }
  .sub-incentive-link {
    display: inline-block;
    position: relative;
    padding: 0.714rem 1.4rem;
    font-size: 0.75em;
    letter-spacing: 0.08em;
    color: inherit;
    text-decoration: none;
    transition: opacity 0.2s;
    white-space: nowrap;
  }
  .sub-incentive-link:hover {
    opacity: 0.6;
  }
  .sub-incentive-link .button-border {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    fill: none;
    stroke: currentColor;
    stroke-opacity: 0.3;
    stroke-width: 1;
    stroke-dasharray: 4 4;
    pointer-events: none;
  }
</style>

{% schema %}
{
  "name": "Subscribe Incentive",
  "tag": "section",
  "class": "subscribe-incentive-section"
}
{% endschema %}
