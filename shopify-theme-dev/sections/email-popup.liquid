{%- comment -%}
  Email capture popup — appears once per visitor after 5 seconds.
  Tied to discount code WELCOME10.
  Matches MAYA design language: monospace, uppercase, dotted borders.
{%- endcomment -%}

<div id="email-popup" class="email-popup" style="display:none">
  <div class="email-popup-overlay"></div>
  <div class="email-popup-inner">
    <button class="email-popup-close" onclick="document.getElementById('email-popup').style.display='none'; localStorage.setItem('maya_popup_dismissed','1');">&times;</button>
    <div class="email-popup-content">
      <p class="email-popup-heading">10% off your first order</p>
      <p class="email-popup-sub">Sign up and receive code WELCOME10 at checkout.</p>
      <form class="email-popup-form" action="https://assets.mailerlite.com/jsonp/2029859/forms/182609108409517586/subscribe" method="post" target="_blank">
        <input type="email" name="fields[email]" class="email-popup-input" placeholder="Email address" required autocomplete="email">
        <input type="hidden" name="ml-submit" value="1">
        <input type="hidden" name="anticsrf" value="true">
        <button type="submit" class="email-popup-submit">
          <svg class="button-border">
            <rect width="calc(100% - 2px)" height="calc(100% - 2px)" rx="5" />
          </svg>
          Join
        </button>
      </form>
      <p class="email-popup-note">Free shipping on orders over $100</p>
    </div>
  </div>
</div>

<script>
  (function() {
    if (localStorage.getItem('maya_popup_dismissed')) return;
    setTimeout(function() {
      var popup = document.getElementById('email-popup');
      if (popup) popup.style.display = 'flex';
    }, 5000);
  })();
</script>

<style>
  .email-popup {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .email-popup-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.4);
    cursor: pointer;
  }
  .email-popup-overlay:hover ~ .email-popup-inner {
    opacity: 0.95;
  }
  .email-popup-inner {
    position: relative;
    background: #f5f5f0;
    padding: 2.5rem;
    max-width: 24rem;
    width: 90%;
    text-align: center;
  }
  .email-popup-close {
    position: absolute;
    top: 0.5rem;
    right: 0.75rem;
    background: none;
    border: none;
    font-size: 1.4em;
    cursor: pointer;
    opacity: 0.5;
    padding: 0;
    line-height: 1;
  }
  .email-popup-close:hover {
    opacity: 1;
  }
  .email-popup-heading {
    font-size: 1.1em;
    letter-spacing: 0.08em;
    margin-bottom: 0.5rem;
  }
  .email-popup-sub {
    font-size: 0.8em;
    opacity: 0.6;
    margin-bottom: 1.5rem;
    line-height: 1.5;
  }
  .email-popup-form {
    display: flex;
    gap: 0;
  }
  .email-popup-input {
    flex: 1;
    background: transparent;
    border: none;
    border-bottom: 1px solid #000;
    padding: 0.5rem 0;
    font-family: inherit;
    font-size: inherit;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    outline: none;
  }
  .email-popup-input::placeholder {
    opacity: 0.4;
  }
  .email-popup-submit {
    position: relative;
    background: none;
    border: none;
    padding: 0.5rem 1rem;
    font-family: inherit;
    font-size: inherit;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    cursor: pointer;
  }
  .email-popup-submit .button-border {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }
  .email-popup-submit .button-border rect {
    x: 1;
    y: 1;
    fill: none;
    stroke: #000;
    stroke-width: 1;
    stroke-dasharray: 2px;
  }
  .email-popup-note {
    font-size: 0.7em;
    opacity: 0.4;
    margin-top: 1rem;
    letter-spacing: 0.06em;
  }
</style>
