<h2 class="footer-newsletter-title">Join the community.</h2>
<form
  class="footer-newsletter"
  action="https://assets.mailerlite.com/jsonp/2029859/forms/182609108409517586/subscribe"
  method="post"
  target="_blank"
>
  <input class="footer-newsletter-input" type="email" name="fields[email]" placeholder="Email address" required autocomplete="email">
  <input type="hidden" name="ml-submit" value="1">
  <input type="hidden" name="anticsrf" value="true">
  <button class="footer-newsletter-submit" type="submit"><span>Join the community</span> <i>→</i></button>
</form>

<div class="footer-social" style="display:flex;gap:1.5rem;justify-content:center;padding:1rem 0;font-size:0.75em;letter-spacing:0.06em;">
  <a href="https://instagram.com/officeofmaya" target="_blank" rel="noopener" style="color:inherit;text-decoration:none;opacity:0.5;transition:opacity 0.2s;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.5'">Instagram</a>
  <a href="https://tiktok.com/@officeofmaya" target="_blank" rel="noopener" style="color:inherit;text-decoration:none;opacity:0.5;transition:opacity 0.2s;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.5'">TikTok</a>
</div>

<div class="footer-end">
  <p class="footer-copyright">
    © {{ 'now' | date: '%Y' }}
    {{ shop.name | link_to: routes.root_url }}
  </p>
  <p>{{ section.settings.footer_text }}</p>
  <a class="footer-credits" href="https://www.officeb.org" target="_blank">Credits</a>

  <ul class="footer-menu">
    {% for link in linklists.footer.links %}
      <li>
        <a class="footer-menu-link" href="{{ link.url }}">{{ link.title }}</a>
      </li>
    {% endfor %}
    <li>
      <a class="footer-menu-link" href="/pages/affiliate-program">Affiliate</a>
    </li>
  </ul>
</div>

{% schema %}
{
  "name": "Footer",
  "tag": "footer",
  "class": "footer",
  "settings": [
    {
      "type": "text",
      "id": "footer_text",
      "label": "Footer text"
    }
  ]
}
{% endschema %}
