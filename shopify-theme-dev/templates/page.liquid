<style>
  .page-content {
    padding: 3rem var(--side-padding);
  }
  .page-content-inner {
    max-width: 42rem;
  }
  .page-content-inner h1 { font-size: 1.4em; letter-spacing: 0.06em; margin-bottom: 2rem; line-height: 1.3; }
  .page-content-inner h2 { font-size: 1em; letter-spacing: 0.08em; margin-top: 2.5rem; margin-bottom: 0.75rem; opacity: 0.7; }
  .page-content-inner h3 { font-size: 0.9em; letter-spacing: 0.06em; margin-top: 1.5rem; margin-bottom: 0.4rem; }
  .page-content-inner p { line-height: 1.7; margin-bottom: 1rem; opacity: 0.8; }
  .page-content-inner a { text-decoration: underline; text-underline-offset: 0.15em; }
  .page-content-inner ul { list-style: none; padding: 0; margin-bottom: 1rem; }
  .page-content-inner ul li { padding: 0.4rem 0; opacity: 0.8; }
  .page-content-inner ul li::before { content: "— "; opacity: 0.4; }
  .seo-crosslinks { margin-top: 3rem; padding-top: 2rem; background: linear-gradient(to right, #000 50%, transparent 50%) top; background-size: 4px 1px; background-repeat: repeat-x; }
  .seo-crosslinks-cta a { display: inline-block; padding: 0.714rem 1.4rem; letter-spacing: 0.08em; font-size: 0.85em; text-decoration: none !important; border: 1px dashed rgba(0,0,0,0.3); border-radius: 6px; transition: border-color 0.2s; }
  .seo-crosslinks-cta a:hover { border-color: rgba(0,0,0,0.6); }
  .seo-crosslinks-bundle { margin-top: 1rem; font-size: 0.85em; opacity: 0.6; }
  .seo-crosslinks-also { margin-top: 1.5rem; font-size: 0.75em; opacity: 0.45; letter-spacing: 0.04em; }
  .seo-crosslinks-also a { opacity: 1; }
</style>
